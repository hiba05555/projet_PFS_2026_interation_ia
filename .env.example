# ============================================================
# FICHIER DE CONFIGURATION — EXEMPLE
# ============================================================
# ⚠️  IMPORTANT :
#   1. Copiez ce fichier : cp .env.example .env
#   2. Remplissez les valeurs réelles dans .env
#   3. N'engagez JAMAIS le fichier .env dans le dépôt git
#      (vérifiez que .gitignore contient bien ".env")
# ============================================================

# ─── Base de données PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_database
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_SSL=false

# ─── JWT ─────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_hex_secret_here

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_URL=amqp://admin:CHANGE_ME@rabbitmq:5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGE_ME

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://votre-domaine.com

# ─── Email (optionnel) ────────────────────────────────────────
# Pour Gmail, utilisez un "App Password" (pas votre mot de passe principal)
# https://myaccount.google.com/apppasswords
GMAIL_USER=votre-email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ─── Monitoring ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ─── Environnement ────────────────────────────────────────────
NODE_ENV=development

# ─── Ports des services ───────────────────────────────────────
GATEWAY_PORT=3000
AUTH_PORT=3001

IT_HELPDESK_PORT=3101
IT_ACCOUNTS_PORT=3102
IT_EQUIPMENT_PORT=3103
IT_MONITORING_PORT=3104
IT_LICENSES_PORT=3105

HR_EMPLOYEES_PORT=3201
HR_LEAVE_PORT=3202
HR_RECRUITMENT_PORT=3203
HR_PAYROLL_PORT=3204
HR_PERFORMANCE_PORT=3205

FINANCE_BUDGET_PORT=3301
FINANCE_REPORTS_PORT=3302
FINANCE_PAYMENTS_PORT=3303
FINANCE_EXPENSES_PORT=3304
FINANCE_INVOICES_PORT=3305

OPS_TASKS_PORT=3401
OPS_WORKFLOWS_PORT=3402
OPS_SUPPLIERS_PORT=3403
OPS_PROJECTS_PORT=3404
OPS_INVENTORY_PORT=3405

# ─── URLs internes Docker ─────────────────────────────────────
AUTH_SERVICE_URL=http://erp-auth:3001
IT_HELPDESK_URL=http://erp-it-helpdesk:3101
IT_ACCOUNTS_URL=http://erp-it-accounts:3102
IT_EQUIPMENT_URL=http://erp-it-equipment:3103
IT_MONITORING_URL=http://erp-it-monitoring:3104
IT_LICENSES_URL=http://erp-it-licenses:3105
HR_EMPLOYEES_URL=http://erp-hr-employees:3201
HR_LEAVE_URL=http://erp-hr-leave:3202
HR_RECRUITMENT_URL=http://erp-hr-recruitment:3203
HR_PAYROLL_URL=http://erp-hr-payroll:3204
HR_PERFORMANCE_URL=http://erp-hr-performance:3205
FINANCE_BUDGET_URL=http://erp-finance-budget:3301
FINANCE_REPORTS_URL=http://erp-finance-reports:3302
FINANCE_PAYMENTS_URL=http://erp-finance-payments:3303
FINANCE_EXPENSES_URL=http://erp-finance-expenses:3304
FINANCE_INVOICES_URL=http://erp-finance-invoices:3305
OPS_TASKS_URL=http://erp-ops-tasks:3401
OPS_WORKFLOWS_URL=http://erp-ops-workflows:3402
OPS_SUPPLIERS_URL=http://erp-ops-suppliers:3403
OPS_PROJECTS_URL=http://erp-ops-projects:3404
OPS_INVENTORY_URL=http://erp-ops-inventory:3405
